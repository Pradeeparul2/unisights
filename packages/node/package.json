{
  "name": "@pradeeparul2/unisights-node",
  "version": "0.0.0-beta.1",
  "description": "Server package for unisights. Creates a configurable endpoint that receives events from the unisights client SDK. Processing is optional. Always returns 200.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pradeeparul2/unisights"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "unisights",
    "analytics",
    "event-collection",
    "express",
    "fastify",
    "nestjs",
    "koa",
    "hono",
    "elysia",
    "cloudflare-workers",
    "deno",
    "bun",
    "vercel-edge",
    "netlify-edge"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
