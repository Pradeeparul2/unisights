{
  "name": "unisights-e2e",
  "private": true,
  "devDependencies": {
    "@fastify/cors": "^9.0.1",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@playwright/test": "^1.44.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fastify": "^4.28.1",
    "@koa/bodyparser": "^5.0.0",
    "koa": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.8.1"
  },
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "servers:express": "tsx frameworks/express.ts",
    "servers:fastapi": "python -m uvicorn frameworks.fastapi:app --port 3002",
    "servers:fastify": "tsx frameworks/fastify.ts",
    "servers:flask": "python -m flask --app frameworks.flask_app run --port 3003",
    "servers:koa": "tsx frameworks/koa.ts",
    "servers:nestjs": "tsx frameworks/nestjs.ts",
    "python:setup": "python -m pip install -r requirements.txt && python -m pip install -e ../packages/python",
    "servers": "concurrently \"npm run servers:express\" \"npm run servers:fastapi\" \"npm run servers:flask\" \"npm run servers:fastify\" \"npm run servers:koa\" \"npm run servers:nestjs\""
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
